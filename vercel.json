{
  "rewrites": [
    { "source": "/",    "destination": "/lead-intel-dashboard.html" },
    { "source": "/hub", "destination": "/index.html" }
  ],
  "functions": {
    "api/scan-leads.js":            { "maxDuration": 60 },
    "api/deliver-leads.js":         { "maxDuration": 90 },
    "api/agent/scan.js":            { "maxDuration": 60 },
    "api/agent/whatsapp-send.js":   { "maxDuration": 15 },
    "api/agent/messages.js":        { "maxDuration": 10 },
    "api/whatsapp-webhook.js":      { "maxDuration": 10 }
  },
  "crons": [
    {
      "path": "/api/auto-scan",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/deliver-leads",
      "schedule": "0 8 * * 1-5"
    }
  ]
}
